PORT=4000
NODE_ENV=development

# PostgreSQL expuesto por Docker en localhost:5432
# 5050 es pgAdmin (interfaz web), no es el puerto de la base de datos.
DB_HOST=localhost
DB_PORT=5432
DB_USER=logixsoft_user
DB_PASSWORD=logixsoft_pass
DB_NAME=logixsoft_db
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000

JWT_SECRET=change_this_secret_in_real_env
JWT_EXPIRES_IN=1d
